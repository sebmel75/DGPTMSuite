// ============================================================
// DGPTM Stipendien — Custom Module Setup
// ============================================================
//
// SCHRITT 1: Custom Module "Stipendien" manuell anlegen
//   Zoho CRM > Setup > Customization > Modules and Fields
//   > Create New Module > Name: "Stipendien" > Singular: "Stipendium"
//
// SCHRITT 2: Connection "zohocrm" anlegen (falls nicht vorhanden)
//   Zoho CRM > Setup > Developer Space > Connections
//   > Create Connection > Service: "Zoho CRM"
//   > Connection Name: "zohocrm"
//   > Scopes: ZohoCRM.settings.fields.ALL, ZohoCRM.modules.ALL
//   > Create & Connect
//
// SCHRITT 3: Lookup-Feld "Bewerber" manuell anlegen
//   Stipendien-Modul > Layout > Neues Feld > Lookup
//   > Name: "Bewerber" > Zielmodul: "Contacts"
//   (Lookup-Felder koennen nicht per API erstellt werden)
//
// SCHRITT 4: Dieses Skript als Custom Function (standalone) ausfuehren
//
// HINWEIS: Falls die Fields API in Ihrer Zoho-Edition nicht verfuegbar ist,
// finden Sie am Ende dieses Skripts eine Anleitung zur manuellen Erstellung.
// ============================================================

module_api_name = "Stipendien";
api_base = "https://www.zohoapis.eu/crm/v8/settings/fields?module=" + module_api_name;
connection_name = "zohocrm";

// ─── Hilfsfunktion: Feld erstellen ───
// (Deluge hat keine echten Funktionen, daher als Inline-Logik)

errors = List();
success_count = 0;

// ═══════════════════════════════════════
// 1. Picklist: Stipendientyp
// ═══════════════════════════════════════
payload = Map();
payload.put("fields", {{"field_label":"Stipendientyp","data_type":"picklist","pick_list_values":{{"display_value":"Promotionsstipendium"},{"display_value":"Josef Guettler Stipendium"}}}});

resp = invokeurl
[
    url: api_base
    type: POST
    parameters: payload.toString()
    headers: {"Content-Type":"application/json"}
    connection: connection_name
];
if (resp.get("fields") != null)
{
    success_count = success_count + 1;
    info "OK: Stipendientyp";
}
else
{
    errors.add("Stipendientyp: " + resp);
    info "FEHLER: Stipendientyp — " + resp;
}

// ═══════════════════════════════════════
// 2. Picklist: Status
// ═══════════════════════════════════════
payload = Map();
payload.put("fields", {{"field_label":"Stipendium_Status","data_type":"picklist","pick_list_values":{{"display_value":"Eingegangen"},{"display_value":"Freigegeben"},{"display_value":"In Bewertung"},{"display_value":"Abgeschlossen"},{"display_value":"Abgelehnt"},{"display_value":"Archiviert"}}}});

resp = invokeurl
[
    url: api_base
    type: POST
    parameters: payload.toString()
    headers: {"Content-Type":"application/json"}
    connection: connection_name
];
if (resp.get("fields") != null)
{
    success_count = success_count + 1;
    info "OK: Status";
}
else
{
    errors.add("Status: " + resp);
    info "FEHLER: Status — " + resp;
}

// ═══════════════════════════════════════
// 3. Single Line: Runde
// ═══════════════════════════════════════
payload = Map();
payload.put("fields", {{"field_label":"Runde","data_type":"text","length":100}});

resp = invokeurl
[
    url: api_base
    type: POST
    parameters: payload.toString()
    headers: {"Content-Type":"application/json"}
    connection: connection_name
];
if (resp.get("fields") != null)
{
    success_count = success_count + 1;
    info "OK: Runde";
}
else
{
    errors.add("Runde: " + resp);
    info "FEHLER: Runde — " + resp;
}

// ═══════════════════════════════════════
// 4. Date-Felder (Batch)
// ═══════════════════════════════════════
date_labels = {"Eingangsdatum","Freigabedatum","Vergabedatum","Stipendium_Abschluss","Runde_Enddatum","Loeschfrist"};

for each dl in date_labels
{
    payload = Map();
    payload.put("fields", {{"field_label":dl,"data_type":"date"}});
    resp = invokeurl
    [
        url: api_base
        type: POST
        parameters: payload.toString()
        headers: {"Content-Type":"application/json"}
        connection: connection_name
    ];
    if (resp.get("fields") != null)
    {
        success_count = success_count + 1;
        info "OK: " + dl;
    }
    else
    {
        errors.add(dl + ": " + resp);
        info "FEHLER: " + dl + " — " + resp;
    }
}

// DateTime: DSGVO Einwilligung
payload = Map();
payload.put("fields", {{"field_label":"DSGVO_Einwilligung_Datum","data_type":"datetime"}});
resp = invokeurl
[
    url: api_base
    type: POST
    parameters: payload.toString()
    headers: {"Content-Type":"application/json"}
    connection: connection_name
];
if (resp.get("fields") != null)
{
    success_count = success_count + 1;
}
else
{
    errors.add("DSGVO_Einwilligung_Datum: " + resp);
}
info "DSGVO_Einwilligung_Datum: " + resp;

// ═══════════════════════════════════════
// 5. URL-Felder (WorkDrive-Links)
// ═══════════════════════════════════════
url_labels = {"Lebenslauf_URL","Motivationsschreiben_URL","Empfehlungsschreiben_URL","Studienleistungen_URL","Publikationen_URL","Zusatzqualifikationen_URL"};

for each ul in url_labels
{
    payload = Map();
    payload.put("fields", {{"field_label":ul,"data_type":"website"}});
    resp = invokeurl
    [
        url: api_base
        type: POST
        parameters: payload.toString()
        headers: {"Content-Type":"application/json"}
        connection: connection_name
    ];
    if (resp.get("fields") != null)
    {
        success_count = success_count + 1;
        info "OK: " + ul;
    }
    else
    {
        errors.add(ul + ": " + resp);
        info "FEHLER: " + ul + " — " + resp;
    }
}

// ═══════════════════════════════════════
// 6. Text-Felder
// ═══════════════════════════════════════
text_labels = {"WorkDrive_Folder_ID","DSGVO_Einwilligung_Hash"};

for each tl in text_labels
{
    payload = Map();
    payload.put("fields", {{"field_label":tl,"data_type":"text","length":255}});
    resp = invokeurl
    [
        url: api_base
        type: POST
        parameters: payload.toString()
        headers: {"Content-Type":"application/json"}
        connection: connection_name
    ];
    if (resp.get("fields") != null)
    {
        success_count = success_count + 1;
        info "OK: " + tl;
    }
    else
    {
        errors.add(tl + ": " + resp);
        info "FEHLER: " + tl + " — " + resp;
    }
}

// ═══════════════════════════════════════
// 7. Decimal: Gesamtscore_Mittelwert
// ═══════════════════════════════════════
payload = Map();
payload.put("fields", {{"field_label":"Gesamtscore_Mittelwert","data_type":"decimal","decimal_place":2}});
resp = invokeurl
[
    url: api_base
    type: POST
    parameters: payload.toString()
    headers: {"Content-Type":"application/json"}
    connection: connection_name
];
if (resp.get("fields") != null) { success_count = success_count + 1; }
else { errors.add("Gesamtscore_Mittelwert: " + resp); }
info "Gesamtscore_Mittelwert: " + resp;

// ═══════════════════════════════════════
// 8. Integer-Felder
// ═══════════════════════════════════════
int_labels = {"Rang","Anzahl_Bewertungen"};

for each il in int_labels
{
    payload = Map();
    payload.put("fields", {{"field_label":il,"data_type":"integer"}});
    resp = invokeurl
    [
        url: api_base
        type: POST
        parameters: payload.toString()
        headers: {"Content-Type":"application/json"}
        connection: connection_name
    ];
    if (resp.get("fields") != null)
    {
        success_count = success_count + 1;
        info "OK: " + il;
    }
    else
    {
        errors.add(il + ": " + resp);
        info "FEHLER: " + il + " — " + resp;
    }
}

// ═══════════════════════════════════════
// 9. Checkbox-Felder (Boolean)
// ═══════════════════════════════════════
bool_labels = {"Foerderfaehig","Vergeben","DSGVO_Einwilligung"};

for each bl in bool_labels
{
    payload = Map();
    payload.put("fields", {{"field_label":bl,"data_type":"checkbox"}});
    resp = invokeurl
    [
        url: api_base
        type: POST
        parameters: payload.toString()
        headers: {"Content-Type":"application/json"}
        connection: connection_name
    ];
    if (resp.get("fields") != null)
    {
        success_count = success_count + 1;
        info "OK: " + bl;
    }
    else
    {
        errors.add(bl + ": " + resp);
        info "FEHLER: " + bl + " — " + resp;
    }
}

// ═══════════════════════════════════════
// Zusammenfassung
// ═══════════════════════════════════════
info "=== ERGEBNIS: " + success_count + " Felder erstellt, " + errors.size() + " Fehler ===";
if (errors.size() > 0)
{
    info "Fehler-Details:";
    for each e in errors
    {
        info "  - " + e;
    }
    info "";
    info "TIPP: Falls alle Felder fehlschlagen, pruefen Sie:";
    info "1. Connection 'zohocrm' vorhanden? (Setup > Developer Space > Connections)";
    info "2. Scopes: ZohoCRM.settings.fields.ALL, ZohoCRM.modules.ALL";
    info "3. Modul 'Stipendien' existiert? (API-Name exakt pruefen)";
    info "4. Zoho CRM Edition: Fields API erfordert Enterprise oder hoeher";
    info "";
    info "FALLBACK: Felder manuell anlegen (siehe Anleitung unten)";
}

// ============================================================
// MANUELLE ANLEITUNG (falls API nicht verfuegbar)
// ============================================================
// Zoho CRM > Setup > Customization > Modules > Stipendien > Layout
//
// LOOKUP-FELDER (zuerst):
//   - "Bewerber" → Contacts
//
// PICKLIST-FELDER:
//   - "Stipendientyp": Promotionsstipendium | Josef Guettler Stipendium
//   - "Stipendium_Status": Eingegangen | Freigegeben | In Bewertung | Abgeschlossen | Abgelehnt | Archiviert
//
// SINGLE LINE TEXT:
//   - "Runde" (max 100 Zeichen)
//   - "WorkDrive_Folder_ID" (max 255 Zeichen)
//   - "DSGVO_Einwilligung_Hash" (max 255 Zeichen)
//
// DATE-FELDER:
//   - Eingangsdatum, Freigabedatum, Vergabedatum
//   - Stipendium_Abschluss, Runde_Enddatum, Loeschfrist
//
// DATETIME-FELD:
//   - DSGVO_Einwilligung_Datum
//
// URL/WEBSITE-FELDER:
//   - Lebenslauf_URL, Motivationsschreiben_URL, Empfehlungsschreiben_URL
//   - Studienleistungen_URL, Publikationen_URL, Zusatzqualifikationen_URL
//
// DEZIMALZAHL (2 Nachkommastellen):
//   - Gesamtscore_Mittelwert
//
// GANZZAHL:
//   - Rang, Anzahl_Bewertungen
//
// CHECKBOX:
//   - Foerderfaehig, Vergeben, DSGVO_Einwilligung
// ============================================================
