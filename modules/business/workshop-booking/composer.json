    "type": "wordpress-plugin-module",
    "license": "proprietary",
    "require": {
        "php": ">=8.1",
        "dompdf/dompdf": "^2.0",
        "endroid/qr-code": "^4.8"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {}
    }
}
